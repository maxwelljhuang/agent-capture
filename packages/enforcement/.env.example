# Enforcement configuration (ENFORCEMENT_*). Copy to .env / a Kubernetes Secret.
# NEVER commit real secrets. See docs/deployment.md + docs/key-management.md.

# --- rules (bank-authored, vendor-loaded) ---
ENFORCEMENT_RULES_PATH=/app/rules.yaml

# --- verdict service ---
ENFORCEMENT_LISTEN_HOST=0.0.0.0
ENFORCEMENT_LISTEN_PORT=8475
# The recorder client presents this on /verdict + resolution polling:
ENFORCEMENT_SERVICE_TOKEN=CHANGEME
ENFORCEMENT_VERDICT_TIMEOUT_MS=150

# --- hold queue (fail-to-human) ---
ENFORCEMENT_DATABASE_URL=postgresql+asyncpg://enforcement:CHANGEME@db:5432/enforcement
ENFORCEMENT_HOLD_TIMEOUT_S=3600
# Human reviewers present this on the /holds review API:
ENFORCEMENT_REVIEWER_TOKEN=CHANGEME
# Bind the reviewer token to ONE tenant — it may then only list/resolve that
# tenant's holds. Leave unset only for an admin/single-tenant deploy (the
# reviewer is otherwise cross-tenant; the service warns loudly at startup).
ENFORCEMENT_REVIEWER_CUSTOMER=acme-bank
ENFORCEMENT_HOLD_POLL_INTERVAL_MS=500
ENFORCEMENT_MAX_HOLD_WAIT_S=3600

# --- ops ---
ENFORCEMENT_LOG_LEVEL=info
