# Ledger configuration (LEDGER_*). Copy to .env / a Kubernetes Secret and fill in.
# NEVER commit real secrets. See docs/deployment.md + docs/key-management.md.

# --- database (least-privileged runtime role) ---
LEDGER_DATABASE_URL=postgresql+asyncpg://ledger_app:CHANGEME@db:5432/ledger
# Role allowed to DELETE (retention worker only):
LEDGER_DATABASE_URL_RETENTION=postgresql+asyncpg://ledger_retention:CHANGEME@db:5432/ledger
# DBA role with CREATE on public (migrations only):
LEDGER_DATABASE_URL_MIGRATE=postgresql+asyncpg://postgres:CHANGEME@db:5432/ledger
LEDGER_DATABASE_POOL_SIZE=10
LEDGER_DATABASE_POOL_MAX_OVERFLOW=20

# --- server ---
LEDGER_LISTEN_HOST=0.0.0.0
LEDGER_LISTEN_PORT=8443
# In-process TLS (optional; prefer ingress termination — see SECURITY.md):
# LEDGER_TLS_CERT_PATH=/secrets/tls.crt
# LEDGER_TLS_KEY_PATH=/secrets/tls.key

# --- attestation signing (Ed25519) ---
LEDGER_SIGNING_KEY_PATH=/secrets/primary.priv.pem
LEDGER_SIGNING_KEY_ID=primary
LEDGER_ATTESTATION_INTERVAL_SECONDS=300
LEDGER_ATTESTATION_SINK=file:///var/lib/ledger/attestations   # or s3://… (append-only)

# --- retention (RetentionClass × age, in days) ---
LEDGER_RETENTION_TRANSIENT_DAYS=7
LEDGER_RETENTION_STANDARD_DAYS=90
LEDGER_RETENTION_EXTENDED_DAYS=2555
LEDGER_RETENTION_HOUR_UTC=3

# --- optional layer-5 advisory enforcement at ingest ---
# LEDGER_ENFORCEMENT_RULES_PATH=/app/rules.yaml

# --- ops ---
LEDGER_BACKPRESSURE_INFLIGHT_HIGH=5000
LEDGER_LOG_LEVEL=info
LEDGER_METRICS_ENABLED=true
